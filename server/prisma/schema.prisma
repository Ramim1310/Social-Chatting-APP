generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  email    String    @unique
  password String
  image    String?
  messages Message[]
  friends  User[]    @relation("UserFriends")
  friendsOf User[]   @relation("UserFriends")
  sentRequests     FriendRequest[] @relation("SentRequests")
  receivedRequests FriendRequest[] @relation("ReceivedRequests")
  
  lastSeen DateTime @default(now())
  bio      String?

  createdCommunities Community[] @relation("CommunityCreator")
  joinedCommunities  Community[] @relation("CommunityMembers")
  posts              Post[]      @relation("UserPosts")
  comments           Threaded_Comment[] @relation("UserComments")
  polls              Poll[]      @relation("UserPolls")
  votes              PollVote[]  @relation("UserVotes")
  createdGroups      Group[]     @relation("GroupCreator")
  joinedGroups       Group[]     @relation("GroupMembers")
}

model Community {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  creatorId   Int
  creator     User     @relation("CommunityCreator", fields: [creatorId], references: [id])
  
  members     User[]   @relation("CommunityMembers")
  posts       Post[]
}

model Group {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  creatorId   Int
  creator     User     @relation("GroupCreator", fields: [creatorId], references: [id])
  
  members     User[]   @relation("GroupMembers")
}

model Post {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authorId    Int
  author      User     @relation("UserPosts", fields: [authorId], references: [id])

  communityId Int
  community   Community @relation(fields: [communityId], references: [id])

  comments    Threaded_Comment[]
  aiInsight   AI_Insight?
}

model Threaded_Comment {
  id          Int      @id @default(autoincrement())
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authorId    Int
  author      User     @relation("UserComments", fields: [authorId], references: [id])

  postId      Int
  post        Post     @relation(fields: [postId], references: [id])

  parentId    Int?
  parent      Threaded_Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies     Threaded_Comment[] @relation("CommentReplies")
}

model AI_Insight {
  id          Int      @id @default(autoincrement())
  summary     String
  keyPoints   String?
  generatedAt DateTime @default(now())

  postId      Int      @unique
  post        Post     @relation(fields: [postId], references: [id])
}

model FriendRequest {
  id         Int      @id @default(autoincrement())
  senderId   Int
  sender     User     @relation("SentRequests", fields: [senderId], references: [id])
  receiverId Int
  receiver   User     @relation("ReceivedRequests", fields: [receiverId], references: [id])
  status     String   @default("pending") // pending, accepted, rejected
  createdAt  DateTime @default(now())
}

model Message {
  id        Int      @id @default(autoincrement())
  content   String
  timestamp DateTime @default(now())
  senderId  Int
  sender    User     @relation(fields: [senderId], references: [id])
  room      String
  
  status      String   @default("sent") // sent, delivered, seen
  deliveredAt DateTime?
  seenAt      DateTime?
}

model NewsArticle {
  id        Int      @id @default(autoincrement())
  title     String
  link      String   @unique
  pubDate   DateTime
  source    String?
  category  String
  createdAt DateTime @default(now())
}

model DecisionNode {
  id        String   @id @default(uuid())
  roomId    String   @unique
  state     Bytes?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Feature: In-Chat Polls ────────────────────────────────────────────────────
model Poll {
  id        Int          @id @default(autoincrement())
  question  String
  room      String
  createdBy Int
  creator   User         @relation("UserPolls", fields: [createdBy], references: [id])
  options   PollOption[]
  closesAt  DateTime?
  isClosed  Boolean      @default(false)
  createdAt DateTime     @default(now())

  @@index([room])
}

model PollOption {
  id     Int        @id @default(autoincrement())
  text   String
  pollId Int
  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes  PollVote[]
}

model PollVote {
  id       Int        @id @default(autoincrement())
  optionId Int
  option   PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  pollId   Int
  userId   Int
  user     User       @relation("UserVotes", fields: [userId], references: [id])
  castAt   DateTime   @default(now())

  @@unique([pollId, userId]) // DB-enforced: one vote per user per poll
}
